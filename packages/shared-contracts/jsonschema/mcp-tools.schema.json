{
  "version": "phase4",
  "description": "MCP tool manifest for video ingestion phase 4.",
  "apiBaseEnv": "VD_API_BASE_URL",
  "$defs": {
    "errorPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "details"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "method": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "status_code": {
              "type": "integer"
            },
            "error": {
              "type": "string"
            },
            "body": {
              "type": "string"
            },
            "body_preview": {
              "type": "string"
            }
          }
        }
      }
    },
    "platform": {
      "type": "string",
      "enum": [
        "bilibili",
        "youtube"
      ]
    },
    "jobStatus": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed"
      ]
    },
    "pipelineFinalStatus": {
      "type": "string",
      "enum": [
        "succeeded",
        "degraded",
        "failed"
      ]
    },
    "videoProcessMode": {
      "type": "string",
      "enum": [
        "full",
        "text_only",
        "refresh_comments",
        "refresh_llm"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "bilibili_uid",
        "youtube_channel_id",
        "url"
      ]
    },
    "subscription": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "source_type",
        "source_value",
        "rsshub_route",
        "enabled",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "platform": {
          "$ref": "#/$defs/platform"
        },
        "source_type": {
          "$ref": "#/$defs/sourceType"
        },
        "source_value": {
          "type": "string"
        },
        "rsshub_route": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "jobStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "attempt",
        "started_at",
        "finished_at",
        "error"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "attempt": {
          "type": "integer"
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "finished_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "jobStepDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "attempt",
        "started_at",
        "finished_at",
        "error",
        "error_kind",
        "retry_meta",
        "result",
        "cache_key"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "attempt": {
          "type": "integer"
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "finished_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "retry_meta": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "result": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "cache_key": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "jobDegradation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step",
        "status",
        "reason",
        "error",
        "error_kind",
        "retry_meta",
        "cache_meta"
      ],
      "properties": {
        "step": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {},
        "error_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "retry_meta": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "cache_meta": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      }
    },
    "notificationRetry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delivery_id",
        "status",
        "attempt_count",
        "next_retry_at",
        "last_error_kind"
      ],
      "properties": {
        "delivery_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        },
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "attempt_count": {
          "type": "integer",
          "minimum": 0
        },
        "next_retry_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "last_error_kind": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "providerHealthSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "ok",
        "warn",
        "fail",
        "last_status",
        "last_checked_at",
        "last_error_kind",
        "last_message"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "ok": {
          "type": "integer",
          "minimum": 0
        },
        "warn": {
          "type": "integer",
          "minimum": 0
        },
        "fail": {
          "type": "integer",
          "minimum": 0
        },
        "last_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_checked_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "last_error_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "last_message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "video_uid",
        "source_url",
        "first_seen_at",
        "last_seen_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "platform": {
          "$ref": "#/$defs/platform"
        },
        "video_uid": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "published_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "first_seen_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_seen_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "anyOf": [
            {
              "$ref": "#/$defs/jobStatus"
            },
            {
              "type": "null"
            }
          ]
        },
        "last_job_id": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid"
        }
      }
    }
  },
  "tools": [
    {
      "name": "vd.subscriptions.list",
      "http": {
        "method": "GET",
        "path": "/api/v1/subscriptions"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "platform": {
            "$ref": "#/$defs/platform"
          },
          "enabled_only": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/subscription"
                }
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.subscriptions.upsert",
      "http": {
        "method": "POST",
        "path": "/api/v1/subscriptions"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "platform",
          "source_type",
          "source_value"
        ],
        "properties": {
          "platform": {
            "$ref": "#/$defs/platform"
          },
          "source_type": {
            "$ref": "#/$defs/sourceType"
          },
          "source_value": {
            "type": "string",
            "minLength": 1
          },
          "rsshub_route": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "subscription",
              "created"
            ],
            "properties": {
              "subscription": {
                "$ref": "#/$defs/subscription"
              },
              "created": {
                "type": "boolean"
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.subscriptions.remove",
      "http": {
        "method": "DELETE",
        "path": "/api/v1/subscriptions/{id}"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ok"
            ],
            "properties": {
              "ok": {
                "type": "boolean"
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.ingest.poll",
      "http": {
        "method": "POST",
        "path": "/api/v1/ingest/poll"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "subscription_id": {
            "type": "string",
            "format": "uuid"
          },
          "platform": {
            "$ref": "#/$defs/platform"
          },
          "max_new_videos": {
            "type": "integer",
            "minimum": 1,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "enqueued",
              "candidates"
            ],
            "properties": {
              "enqueued": {
                "type": "integer",
                "minimum": 0
              },
              "candidates": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "video_id",
                    "platform",
                    "video_uid",
                    "source_url",
                    "job_id"
                  ],
                  "properties": {
                    "video_id": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "platform": {
                      "$ref": "#/$defs/platform"
                    },
                    "video_uid": {
                      "type": "string"
                    },
                    "source_url": {
                      "type": "string"
                    },
                    "title": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "published_at": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "date-time"
                    },
                    "job_id": {
                      "type": "string",
                      "format": "uuid"
                    }
                  }
                }
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.jobs.get",
      "http": {
        "method": "GET",
        "path": "/api/v1/jobs/{job_id}"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "job_id"
        ],
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "video_id",
              "kind",
              "status",
              "idempotency_key",
              "error_message",
              "artifact_digest_md",
              "artifact_root",
              "llm_required",
              "llm_gate_passed",
              "hard_fail_reason",
              "created_at",
              "updated_at",
              "step_summary",
              "steps",
              "degradations",
              "pipeline_final_status",
              "artifacts_index",
              "mode",
              "notification_retry"
            ],
            "properties": {
              "id": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "uuid"
              },
              "video_id": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "uuid"
              },
              "kind": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/jobStatus"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "idempotency_key": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "error_message": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "artifact_digest_md": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "artifact_root": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "llm_required": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "llm_gate_passed": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "hard_fail_reason": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "created_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "updated_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "step_summary": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/jobStep"
                }
              },
              "steps": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/jobStepDetail"
                }
              },
              "degradations": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/jobDegradation"
                }
              },
              "pipeline_final_status": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/pipelineFinalStatus"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "artifacts_index": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "mode": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/videoProcessMode"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "notification_retry": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/notificationRetry"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.videos.list",
      "http": {
        "method": "GET",
        "path": "/api/v1/videos"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "platform": {
            "$ref": "#/$defs/platform"
          },
          "status": {
            "$ref": "#/$defs/jobStatus"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/video"
                }
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.videos.process",
      "http": {
        "method": "POST",
        "path": "/api/v1/videos/process"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "video"
        ],
        "properties": {
          "video": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "platform",
              "url"
            ],
            "properties": {
              "platform": {
                "$ref": "#/$defs/platform"
              },
              "url": {
                "type": "string",
                "minLength": 1
              },
              "video_id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "mode": {
            "$ref": "#/$defs/videoProcessMode",
            "default": "full"
          },
          "overrides": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          },
          "force": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "job_id",
              "video_db_id",
              "video_uid",
              "status",
              "idempotency_key",
              "mode",
              "overrides",
              "force",
              "reused",
              "workflow_id"
            ],
            "properties": {
              "job_id": {
                "type": "string",
                "format": "uuid"
              },
              "video_db_id": {
                "type": "string",
                "format": "uuid"
              },
              "video_uid": {
                "type": "string"
              },
              "status": {
                "$ref": "#/$defs/jobStatus"
              },
              "idempotency_key": {
                "type": "string"
              },
              "mode": {
                "$ref": "#/$defs/videoProcessMode"
              },
              "overrides": {
                "type": "object",
                "additionalProperties": true
              },
              "force": {
                "type": "boolean"
              },
              "reused": {
                "type": "boolean"
              },
              "workflow_id": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.health.providers",
      "http": {
        "method": "GET",
        "path": "/api/v1/health/providers"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "window_hours": {
            "type": "integer",
            "minimum": 1,
            "maximum": 168,
            "default": 24
          }
        }
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "window_hours",
              "providers"
            ],
            "properties": {
              "window_hours": {
                "type": "integer",
                "minimum": 1
              },
              "providers": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/providerHealthSummary"
                }
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.artifacts.get_markdown",
      "http": {
        "method": "GET",
        "path": "/api/v1/artifacts/markdown"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "job_id": {
            "type": "string",
            "format": "uuid"
          },
          "video_url": {
            "type": "string",
            "minLength": 1
          }
        },
        "anyOf": [
          {
            "required": [
              "job_id"
            ]
          },
          {
            "required": [
              "video_url"
            ]
          }
        ]
      },
      "outputSchema": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "markdown",
              "job_id",
              "video_url",
              "found"
            ],
            "properties": {
              "markdown": {
                "type": "string"
              },
              "job_id": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "uuid"
              },
              "video_url": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "found": {
                "type": "boolean"
              }
            }
          },
          {
            "$ref": "#/$defs/errorPayload"
          }
        ]
      }
    },
    {
      "name": "vd.notifications.send_test",
      "http": {
        "method": "POST",
        "path": "/api/v1/notifications/test"
      },
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "to_email": {
            "type": "string",
            "minLength": 1
          },
          "subject": {
