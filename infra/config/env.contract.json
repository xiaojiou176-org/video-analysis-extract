{
  "version": 1,
  "variables": [
    {
      "name": "APP_NAME",
      "scope": "api",
      "required": false,
      "secret": false,
      "default": "Video Digestor API",
      "consumer": ["apps/api/app/config.py"],
      "description": "API service display name."
    },
    {
      "name": "APP_VERSION",
      "scope": "api",
      "required": false,
      "secret": false,
      "default": "0.1.0",
      "consumer": ["apps/api/app/config.py"],
      "description": "API service display version."
    },
    {
      "name": "DATABASE_URL",
      "scope": "shared",
      "required": true,
      "secret": true,
      "default": null,
      "consumer": ["apps/api/app/config.py", "apps/worker/worker/config.py"],
      "description": "Primary SQL database DSN."
    },
    {
      "name": "TEMPORAL_TARGET_HOST",
      "scope": "shared",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/api/app/config.py", "apps/worker/worker/config.py"],
      "description": "Temporal frontend host:port."
    },
    {
      "name": "TEMPORAL_NAMESPACE",
      "scope": "shared",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/api/app/config.py", "apps/worker/worker/config.py"],
      "description": "Temporal namespace."
    },
    {
      "name": "TEMPORAL_TASK_QUEUE",
      "scope": "shared",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/api/app/config.py", "apps/worker/worker/config.py"],
      "description": "Temporal task queue name."
    },
    {
      "name": "SQLITE_STATE_PATH",
      "scope": "api",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/api/app/config.py"],
      "description": "API reads pipeline step state from this SQLite DB."
    },
    {
      "name": "SQLITE_PATH",
      "scope": "worker",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Worker SQLite state DB path."
    },
    {
      "name": "PIPELINE_WORKSPACE_DIR",
      "scope": "worker",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Worker workspace directory."
    },
    {
      "name": "PIPELINE_ARTIFACT_ROOT",
      "scope": "worker",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Pipeline artifact output root."
    },
    {
      "name": "NOTIFICATION_ENABLED",
      "scope": "shared",
      "required": false,
      "secret": false,
      "default": "false",
      "consumer": ["apps/api/app/config.py", "apps/worker/worker/config.py"],
      "description": "Enable outbound notification delivery."
    },
    {
      "name": "RESEND_API_KEY",
      "scope": "shared",
      "required": false,
      "secret": true,
      "default": null,
      "consumer": ["apps/api/app/config.py", "apps/worker/worker/config.py"],
      "description": "Resend API key, required when notifications are enabled."
    },
    {
      "name": "RESEND_FROM_EMAIL",
      "scope": "shared",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/api/app/config.py", "apps/worker/worker/config.py"],
      "description": "Resend sender address, required when notifications are enabled."
    },
    {
      "name": "VD_API_BASE_URL",
      "scope": "shared",
      "required": true,
      "secret": false,
      "default": null,
      "consumer": ["apps/mcp/server.py", "apps/web/lib/api/client.ts", "scripts/*.sh"],
      "description": "Base URL for API HTTP calls."
    },
    {
      "name": "VD_API_TIMEOUT_SEC",
      "scope": "mcp",
      "required": false,
      "secret": false,
      "default": "20",
      "consumer": ["apps/mcp/server.py"],
      "description": "MCP upstream HTTP timeout seconds."
    },
    {
      "name": "VD_API_KEY",
      "scope": "mcp",
      "required": false,
      "secret": true,
      "default": null,
      "consumer": ["apps/mcp/server.py"],
      "description": "Optional bearer token for MCP -> API requests."
    },
    {
      "name": "NEXT_PUBLIC_API_BASE_URL",
      "scope": "web",
      "required": false,
      "secret": false,
      "default": "http://127.0.0.1:8000",
      "consumer": ["apps/web/lib/api/client.ts"],
      "description": "Public API URL for web bundle/runtime."
    },
    {
      "name": "RSSHUB_BASE_URL",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "https://rsshub.app",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "RSSHub base URL for feed normalization."
    },
    {
      "name": "FEED_URLS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Comma-separated feed URLs."
    },
    {
      "name": "FEED_PATHS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Comma-separated feed paths resolved against RSSHUB_BASE_URL."
    },
    {
      "name": "REQUEST_TIMEOUT_SECONDS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "15",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "HTTP request timeout in seconds."
    },
    {
      "name": "REQUEST_RETRY_ATTEMPTS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "3",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Retry attempts for RSS/API requests."
    },
    {
      "name": "REQUEST_RETRY_BACKOFF_SECONDS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "0.5",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Retry backoff base seconds."
    },
    {
      "name": "COMMENTS_TOP_N",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "10",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Maximum top-level comments fetched."
    },
    {
      "name": "COMMENTS_REPLIES_PER_COMMENT",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "10",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Replies fetched per top-level comment."
    },
    {
      "name": "COMMENTS_REQUEST_TIMEOUT_SECONDS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "10",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Comment API timeout seconds."
    },
    {
      "name": "LOCK_TTL_SECONDS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "90",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "SQLite lock TTL seconds."
    },
    {
      "name": "PIPELINE_RETRY_ATTEMPTS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "2",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Pipeline step retry attempts."
    },
    {
      "name": "PIPELINE_RETRY_BACKOFF_SECONDS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "1.0",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Pipeline retry backoff seconds."
    },
    {
      "name": "PIPELINE_SUBPROCESS_TIMEOUT_SECONDS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "180",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Subprocess timeout seconds."
    },
    {
      "name": "BILIBILI_DOWNLOADER",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "auto",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Bilibili download provider strategy: auto | yt-dlp | bbdown."
    },
    {
      "name": "BILIBILI_COOKIE",
      "scope": "worker",
      "required": false,
      "secret": true,
      "default": null,
      "consumer": ["apps/worker/worker/config.py", "apps/worker/worker/comments/bilibili.py"],
      "description": "Optional bilibili cookie header used to reduce anti-crawl failures (e.g. code -352)."
    },
    {
      "name": "YOUTUBE_TRANSCRIPT_FALLBACK_ENABLED",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "true",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Enable YouTube transcript API fallback when subtitle files are unavailable."
    },
    {
      "name": "ASR_FALLBACK_ENABLED",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "false",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Enable local ASR fallback when subtitles/transcript fallback are unavailable."
    },
    {
      "name": "ASR_MODEL_SIZE",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "small",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Default local ASR model size."
    },
    {
      "name": "PIPELINE_MAX_FRAMES",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "6",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Max frames extracted for multimodal inputs."
    },
    {
      "name": "PIPELINE_FRAME_INTERVAL_SECONDS",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "30",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Frame extraction interval seconds."
    },
    {
      "name": "PIPELINE_LLM_INPUT_MODE",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "auto",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "LLM input mode strategy."
    },
    {
      "name": "PIPELINE_LLM_INCLUDE_FRAMES",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/pipeline/runner_rendering.py"],
      "description": "Override to force frame inclusion for LLM input."
    },
    {
      "name": "PIPELINE_LLM_HARD_REQUIRED",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "true",
      "consumer": ["apps/worker/worker/pipeline/policies.py"],
      "description": "When true, llm_outline/llm_digest failures are treated as hard failures."
    },
    {
      "name": "PIPELINE_LLM_FAIL_ON_PROVIDER_ERROR",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "true",
      "consumer": ["apps/worker/worker/pipeline/policies.py"],
      "description": "When true, provider/API errors in LLM steps fail the job rather than degrade."
    },
    {
      "name": "PIPELINE_LLM_MAX_RETRIES",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/pipeline/policies.py"],
      "description": "Optional retry override for llm_outline and llm_digest steps."
    },
    {
      "name": "DIGEST_TEMPLATE_PATH",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Custom digest template path."
    },
    {
      "name": "DIGEST_LOCAL_TIMEZONE",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "IANA timezone used by DailyDigestWorkflow scheduling."
    },
    {
      "name": "DIGEST_DAILY_LOCAL_HOUR",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "9",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Local-hour trigger for daily digest scheduling."
    },
    {
      "name": "GEMINI_API_KEY",
      "scope": "worker",
      "required": false,
      "secret": true,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Gemini API key."
    },
    {
      "name": "GEMINI_MODEL",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "gemini-3.1-pro-preview",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Gemini model name."
    },
    {
      "name": "GEMINI_OUTLINE_MODEL",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "GEMINI_MODEL",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Gemini model for llm_outline step."
    },
    {
      "name": "GEMINI_DIGEST_MODEL",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "GEMINI_MODEL",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Gemini model for llm_digest step."
    },
    {
      "name": "GEMINI_FAST_MODEL",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "gemini-3-flash-preview",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Gemini model for speed-priority jobs."
    },
    {
      "name": "GEMINI_EMBEDDING_MODEL",
      "scope": "worker",
      "required": false,
      "secret": false,
      "default": "gemini-embedding-001",
      "consumer": ["apps/worker/worker/config.py"],
      "description": "Gemini embeddings model for vectorization."
    },
    {
      "name": "YOUTUBE_API_KEY",
      "scope": "worker",
      "required": false,
      "secret": true,
      "default": null,
      "consumer": ["apps/worker/worker/config.py"],
      "description": "YouTube Data API key for comments."
    },
    {
      "name": "DIGEST_CHANNEL",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "email",
      "consumer": ["scripts/run_daily_digest.sh"],
      "description": "Daily digest channel."
    },
    {
      "name": "DIGEST_DRY_RUN",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "false",
      "consumer": ["scripts/run_daily_digest.sh"],
      "description": "Daily digest dry-run toggle."
    },
    {
      "name": "DIGEST_FORCE",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "false",
      "consumer": ["scripts/run_daily_digest.sh"],
      "description": "Daily digest force-send toggle."
    },
    {
      "name": "DIGEST_FALLBACK_ENABLED",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "1",
      "consumer": ["scripts/run_daily_digest.sh"],
      "description": "Enable fallback send path for daily digest."
    },
    {
      "name": "DIGEST_TO_EMAIL",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["scripts/run_daily_digest.sh"],
      "description": "Override digest recipient."
    },
    {
      "name": "DIGEST_DATE",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["scripts/run_daily_digest.sh"],
      "description": "Digest date override (YYYY-MM-DD)."
    },
    {
      "name": "LIVE_SMOKE_TIMEOUT_SECONDS",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "60",
      "consumer": ["scripts/e2e_live_smoke.sh"],
      "description": "Timeout seconds for provider canary run in live smoke script."
    },
    {
      "name": "LIVE_SMOKE_REQUIRE_API",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "0",
      "consumer": ["scripts/e2e_live_smoke.sh"],
      "description": "When true, fail live smoke if API is not reachable; otherwise skip."
    },
    {
      "name": "YOUTUBE_SMOKE_URL",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
      "consumer": ["scripts/e2e_live_smoke.sh"],
      "description": "YouTube URL used by live smoke process scenario."
    },
    {
      "name": "BILIBILI_SMOKE_URL",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "https://www.bilibili.com/video/BV1xx411c7mD",
      "consumer": ["scripts/e2e_live_smoke.sh"],
      "description": "Bilibili URL used by live smoke process scenario."
    },
    {
      "name": "FAILURE_CHANNEL",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "email",
      "consumer": ["scripts/run_failure_alerts.sh"],
      "description": "Failure alert channel."
    },
    {
      "name": "FAILURE_LOOKBACK_HOURS",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "24",
      "consumer": ["scripts/run_failure_alerts.sh"],
      "description": "Failure alert lookback window."
    },
    {
      "name": "FAILURE_LIMIT",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "20",
      "consumer": ["scripts/run_failure_alerts.sh"],
      "description": "Maximum failed jobs to include."
    },
    {
      "name": "FAILURE_DRY_RUN",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "false",
      "consumer": ["scripts/run_failure_alerts.sh"],
      "description": "Failure alert dry-run toggle."
    },
    {
      "name": "FAILURE_FORCE",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "false",
      "consumer": ["scripts/run_failure_alerts.sh"],
      "description": "Failure alert force-send toggle."
    },
    {
      "name": "FAILURE_FALLBACK_ENABLED",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "1",
      "consumer": ["scripts/run_failure_alerts.sh"],
      "description": "Enable fallback path for failure alerts."
    },
    {
      "name": "FAILURE_TO_EMAIL",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["scripts/run_failure_alerts.sh"],
      "description": "Override failure alert recipient."
    },
    {
      "name": "NOTIFY_TO_EMAIL",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["scripts/run_daily_digest.sh", "scripts/run_failure_alerts.sh"],
      "description": "Shared local default recipient for script overrides."
    },
    {
      "name": "API_APP",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "apps.api.app.main:app",
      "consumer": ["scripts/dev_api.sh"],
      "description": "Uvicorn app import path."
    },
    {
      "name": "API_HOST",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "127.0.0.1",
      "consumer": ["scripts/dev_api.sh"],
      "description": "API listen host."
    },
    {
      "name": "API_PORT",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "8000",
      "consumer": ["scripts/dev_api.sh"],
      "description": "API listen port."
    },
    {
      "name": "WORKER_DIR",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "apps/worker",
      "consumer": ["scripts/dev_worker.sh"],
      "description": "Worker module root."
    },
    {
      "name": "WORKER_ENTRY",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "worker.main",
      "consumer": ["scripts/dev_worker.sh"],
      "description": "Worker Python entry module."
    },
    {
      "name": "WORKER_COMMAND",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "run-worker",
      "consumer": ["scripts/dev_worker.sh"],
      "description": "Worker command for the entry module."
    },
    {
      "name": "DEV_WORKER_SHOW_HINTS",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "1",
      "consumer": ["scripts/dev_worker.sh"],
      "description": "Print environment hints before worker startup."
    },
    {
      "name": "MCP_DIR",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "apps/mcp",
      "consumer": ["scripts/dev_mcp.sh"],
      "description": "MCP server root directory."
    },
    {
      "name": "MCP_ENTRY",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "apps.mcp.server",
      "consumer": ["scripts/dev_mcp.sh"],
      "description": "MCP Python entry module."
    },
    {
      "name": "OUTPUT_PATH",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": ".env.local.example",
      "consumer": ["scripts/init_env_example.sh"],
      "description": "Generated local env template path."
    },
    {
      "name": "INIT_ENV_FORCE",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "0",
      "consumer": ["scripts/init_env_example.sh"],
      "description": "Overwrite generated template when set to truthy."
    },
    {
      "name": "WEB_BASE_URL",
      "scope": "test",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/web/tests/e2e/test_smoke_playwright.py"],
      "description": "Target URL for web E2E smoke tests."
    },
    {
      "name": "WEB_E2E_EXPECT_TEXT",
      "scope": "test",
      "required": false,
      "secret": false,
      "default": null,
      "consumer": ["apps/web/tests/e2e/test_smoke_playwright.py"],
      "description": "Expected response text for web E2E smoke tests."
    }
  ]
}
