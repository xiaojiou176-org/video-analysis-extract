{
  "version": 1,
  "name": "scripts",
  "variables": [
    {
      "name": "CORE_POSTGRES_PASSWORD",
      "scope": "scripts",
      "required": false,
      "secret": true,
      "default": "postgres",
      "consumer": [
        "infra/compose/core-services.compose.yml"
      ],
      "description": "Core services PostgreSQL password override."
    },
    {
      "name": "CORE_POSTGRES_PORT",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "5432",
      "consumer": [
        "infra/compose/core-services.compose.yml"
      ],
      "description": "Core services PostgreSQL exposed host port."
    },
    {
      "name": "MINIFLUX_ADMIN_PASSWORD",
      "scope": "scripts",
      "required": false,
      "secret": true,
      "default": null,
      "consumer": [
        "scripts/deploy_reader_stack.sh",
        "scripts/sync_ai_feed_to_miniflux.py"
      ],
      "description": "Miniflux admin password."
    },
    {
      "name": "MINIFLUX_ADMIN_USERNAME",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "admin",
      "consumer": [
        "scripts/deploy_reader_stack.sh",
        "scripts/sync_ai_feed_to_miniflux.py"
      ],
      "description": "Miniflux admin username."
    },
    {
      "name": "MINIFLUX_API_TOKEN",
      "scope": "scripts",
      "required": false,
      "secret": true,
      "default": null,
      "consumer": [
        "scripts/sync_ai_feed_to_miniflux.py"
      ],
      "description": "Miniflux API token for AI sync."
    },
    {
      "name": "MINIFLUX_DB_PASSWORD",
      "scope": "scripts",
      "required": false,
      "secret": true,
      "default": "change_me",
      "consumer": [
        "infra/compose/miniflux-nextflux.compose.yml"
      ],
      "description": "PostgreSQL password for Miniflux container."
    },
    {
      "name": "NEXTFLUX_PORT",
      "scope": "scripts",
      "required": false,
      "secret": false,
      "default": "3000",
      "consumer": [
        "scripts/deploy_reader_stack.sh",
        "scripts/smoke_full_stack.sh"
      ],
      "description": "Nextflux exposed port."
    }
  ]
}
