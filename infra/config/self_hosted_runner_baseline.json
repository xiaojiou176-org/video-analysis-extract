{
  "version": 1,
  "profiles": {
    "preflight-fast": {
      "commands": [
        "bash",
        "python3",
        "git",
        "docker",
        "rg"
      ],
      "docker_compose_required": true,
      "disk_budget_gb": {
        "min_free_gb_tmp": 4,
        "min_free_gb_workspace": 4
      },
      "purge_paths": [
        ".runtime-cache",
        "mutants/",
        "/tmp/video-digestor-strict-ci"
      ]
    },
    "runner-health": {
      "commands": [
        "bash",
        "python3",
        "git",
        "docker",
        "gh",
        "gcloud",
        "jq",
        "rg"
      ],
      "docker_compose_required": false,
      "disk_budget_gb": {
        "min_free_gb_tmp": 4,
        "min_free_gb_workspace": 4
      },
      "purge_paths": [
        ".runtime-cache",
        "_diag/pages/*"
      ]
    },
    "ci-heavy": {
      "commands": [
        "bash",
        "python3",
        "git",
        "rg"
      ],
      "docker_compose_required": false,
      "disk_budget_gb": {
        "min_free_gb_tmp": 8,
        "min_free_gb_workspace": 8
      },
      "purge_paths": [
        ".runtime-cache",
        "mutants/",
        "/tmp/video-digestor-strict-ci",
        "/tmp/video-digestor-*",
        "/tmp/temporal-cli-*"
      ]
    }
  }
}
