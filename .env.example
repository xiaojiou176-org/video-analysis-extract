# Canonical minimal environment template for local development.
# Copy this file to .env, then fill secrets as needed.
# Full script override catalog: docs/reference/env-script-overrides.md

# ---------- Core Runtime (required) ----------
export APP_NAME='Video Digestor API'
export APP_VERSION='0.1.0'
export DATABASE_URL='postgresql+psycopg://postgres:postgres@127.0.0.1:5432/video_analysis'
export TEMPORAL_TARGET_HOST='127.0.0.1:7233'
export TEMPORAL_NAMESPACE='default'
export TEMPORAL_TASK_QUEUE='video-analysis-worker'
export SQLITE_PATH="$HOME/.video-digestor/state/worker_state.db"
export SQLITE_STATE_PATH="$HOME/.video-digestor/state/worker_state.db"
export PIPELINE_WORKSPACE_DIR="$HOME/.video-digestor/workspace"
export PIPELINE_ARTIFACT_ROOT="$HOME/.video-digestor/artifacts"

# ---------- API / MCP / Web (startup essentials) ----------
export API_PORT='9000'
export WEB_PORT='3000'
# Routing source of truth is API_PORT/WEB_PORT.
# Keep base URLs aligned with API_PORT; full-stack runtime may emit effective values to
# .runtime-cache/full-stack/resolved.env without rewriting .env.
export VD_API_BASE_URL='http://127.0.0.1:9000'
export VD_API_TIMEOUT_SEC='20'
export VD_API_RETRY_ATTEMPTS='1'
export VD_API_RETRY_BACKOFF_SEC='0.2'
# export VD_API_KEY='<optional>'
export VD_ALLOW_UNAUTH_WRITE='false'
export VD_CI_ALLOW_UNAUTH_WRITE='false'
export NEXT_PUBLIC_API_BASE_URL='http://127.0.0.1:9000'
export UI_AUDIT_GEMINI_ENABLED='true'
export UI_AUDIT_ARTIFACT_BASE_ROOT="$HOME/.video-digestor/artifacts"
export UI_AUDIT_RUN_STORE_DIR='.runtime-cache/ui-audit-runs'
export VD_MCP_MAX_BASE64_BYTES='2097152'

# ---------- Worker Runtime (common local defaults) ----------
export RSSHUB_BASE_URL='https://rsshub.app'
export RSSHUB_PUBLIC_FALLBACK_BASE_URL='https://rsshub.app'
export REQUEST_TIMEOUT_SECONDS='15'
export REQUEST_RETRY_ATTEMPTS='3'
export REQUEST_RETRY_BACKOFF_SECONDS='0.5'
export COMMENTS_TOP_N='10'
export COMMENTS_REPLIES_PER_COMMENT='10'
export COMMENTS_REQUEST_TIMEOUT_SECONDS='10'
export LOCK_TTL_SECONDS='90'
export PIPELINE_RETRY_ATTEMPTS='2'
export PIPELINE_RETRY_BACKOFF_SECONDS='1.0'
export PIPELINE_SUBPROCESS_TIMEOUT_SECONDS='180'
export BILIBILI_DOWNLOADER='auto'
export YOUTUBE_TRANSCRIPT_FALLBACK_ENABLED='true'
export ASR_FALLBACK_ENABLED='false'
export ASR_MODEL_SIZE='small'
export PIPELINE_MAX_FRAMES='6'
export PIPELINE_FRAME_INTERVAL_SECONDS='30'
export PIPELINE_LLM_INPUT_MODE='auto'
export PIPELINE_LLM_HARD_REQUIRED='true'
export PIPELINE_LLM_FAIL_ON_PROVIDER_ERROR='true'
export DIGEST_LOCAL_TIMEZONE='America/Los_Angeles'
export DIGEST_DAILY_LOCAL_HOUR='9'

# ---------- LLM / External APIs ----------
export LLM_PROVIDER='gemini'
# export GEMINI_API_KEY='<optional>'
export GEMINI_MODEL='gemini-3.1-pro-preview'
export GEMINI_OUTLINE_MODEL='gemini-3.1-pro-preview'
export GEMINI_DIGEST_MODEL='gemini-3.1-pro-preview'
export GEMINI_FAST_MODEL='gemini-3.0-flash'
export GEMINI_COMPUTER_USE_MODEL='gemini-2.5-computer-use-preview-10-2025'
export GEMINI_EMBEDDING_MODEL='gemini-embedding-001'
export GEMINI_THINKING_LEVEL='high'
# export GEMINI_UI_UX_AUDIT_REPORT_PATH='.runtime-cache/ui-audit/gemini-ui-ux-audit-report.json'
export GEMINI_INCLUDE_THOUGHTS='true'
export GEMINI_STRICT_SCHEMA_MODE='true'
export GEMINI_CONTEXT_CACHE_ENABLED='true'
export GEMINI_COMPUTER_USE_ENABLED='false'
export GEMINI_COMPUTER_USE_REQUIRE_CONFIRMATION='true'
# export YOUTUBE_API_KEY='<optional>'

# ---------- Notifications ----------
export NOTIFICATION_ENABLED='false'
# export RESEND_API_KEY='<required-when-notification-enabled>'
# export RESEND_FROM_EMAIL='Video Digestor <noreply@example.com>'

# ---------- Optional scripts: full list moved ----------
# For script tuning variables, see: docs/reference/env-script-overrides.md
# Note: Batch A controls for start_ops_workflows were migrated from env vars
# to CLI flags (workflow-id/run-once/show-hints/dry-run/timezone-offset).

# ---------- CI / Test behavior toggles (optional) ----------
# CI and GITHUB_ACTIONS are injected by hosted CI by default.
# export CI='1'
# export GITHUB_ACTIONS='true'
# Optional defaults for shared runner maintenance helper scripts:
# export GCP_PROJECT_ID='project-73ca1c4a-1270-4025-a65'
# export GCP_ZONE='us-central1-a'
# Optional local-only GHCR auth for strict CI image pulls:
# export GHCR_USERNAME='xiaojiou176'
# export GHCR_TOKEN='<classic-pat-with-read/write-packages>'
# Local-only debug switch for web e2e mock mode.
# CI/mainline must keep real API path (do NOT enable in CI).
# export WEB_E2E_USE_MOCK_API='0'
# Optional E2E-only Next distDir isolation to avoid concurrent .next/dev lock contention.
# export WEB_E2E_NEXT_DIST_DIR='.next-e2e'
# Local strictness override for api integration smoke:
# 0/unset = fast local mode (unmet real-Postgres requirements may xfail)
# 1 = strict local mode (require real Postgres integration smoke to pass)
# export API_INTEGRATION_SMOKE_STRICT='0'
# Live smoke target override (local default is http://127.0.0.1:9000 in scripts):
# export LIVE_SMOKE_API_BASE_URL='http://127.0.0.1:9000'
# Live smoke strict defaults are CLI-first: --require-api=1 and --require-secrets=1.
# For local debugging only, override via script flags instead of persisting here.
# Live smoke runtime PIDs are exported by CI workflow steps for process liveness checks:
# export LIVE_SMOKE_API_PID=''
# export LIVE_SMOKE_WORKER_PID=''
# export LIVE_SMOKE_TEMPORAL_PID=''
# CI pins Temporal CLI install/version via workflow env:
# export TEMPORAL_CLI_VERSION='1.5.1'
# export TEMPORAL_CLI_SHA256_LINUX_AMD64='ddc95e08b0b076efd4ea9733a3f488eb7d2be875f8834e616cd2a37358b4852d'
# export TEMPORAL_CLI_SHA256_LINUX_ARM64='bd1b0db9f18b051026de8bf6cc1505f2510f14bbb7a8b9a4a91fff46c77454f5'
# Optional strict-runtime overrides for local standard-env / web-e2e debug runs.
# export TMPDIR='/tmp'
# export UV_LINK_MODE='copy'
# export UV_PROJECT_ENVIRONMENT=''
