# Canonical environment template for local development.
# Copy this file to .env and fill secrets before running local services.
# .env.local is legacy fallback only when .env is absent.

# ---------- Core Runtime ----------
export APP_NAME='Video Digestor API'
export APP_VERSION='0.1.0'
export DATABASE_URL='postgresql+psycopg://localhost:5432/video_analysis'
# Optional admin DSN used by API integration smoke tests to create ephemeral databases.
# export API_INTEGRATION_DATABASE_URL='postgresql+psycopg://postgres:postgres@127.0.0.1:5432/postgres'
export TEMPORAL_TARGET_HOST='127.0.0.1:7233'
export TEMPORAL_NAMESPACE='default'
export TEMPORAL_TASK_QUEUE='video-analysis-worker'

export SQLITE_PATH="$HOME/.video-digestor/state/worker_state.db"
export SQLITE_STATE_PATH="$HOME/.video-digestor/state/worker_state.db"
export PIPELINE_WORKSPACE_DIR="$HOME/.video-digestor/workspace"
export PIPELINE_ARTIFACT_ROOT="$HOME/.video-digestor/artifacts"

# ---------- API / MCP / Web ----------
export VD_API_BASE_URL='http://127.0.0.1:8000'
export VD_API_TIMEOUT_SEC='20'
# export VD_API_KEY='<optional>'
export NEXT_PUBLIC_API_BASE_URL='http://127.0.0.1:8000'
export UI_AUDIT_GEMINI_ENABLED='true'
export WEB_BASE_URL='http://127.0.0.1:3000'
# export WEB_E2E_EXPECT_TEXT='Video Digestor'
# Optional e2e worker isolation overrides.
# export NEXT_DIST_DIR='.next-e2e-gw0'
# export WEB_E2E_BROWSER='chromium'
# export PYTEST_XDIST_WORKER='gw0'

# ---------- Worker Runtime ----------
export RSSHUB_BASE_URL='https://rsshub.app'
# export FEED_URLS='https://rsshub.app/youtube/channel/UC_x5XG1OV2P6uZZ5FSM9Ttw'
# export FEED_PATHS='/youtube/channel/UC_x5XG1OV2P6uZZ5FSM9Ttw'
export REQUEST_TIMEOUT_SECONDS='15'
export REQUEST_RETRY_ATTEMPTS='3'
export REQUEST_RETRY_BACKOFF_SECONDS='0.5'
export COMMENTS_TOP_N='10'
export COMMENTS_REPLIES_PER_COMMENT='10'
export COMMENTS_REQUEST_TIMEOUT_SECONDS='10'
export LOCK_TTL_SECONDS='90'

export PIPELINE_RETRY_ATTEMPTS='2'
export PIPELINE_RETRY_BACKOFF_SECONDS='1.0'
export PIPELINE_SUBPROCESS_TIMEOUT_SECONDS='180'
export BILIBILI_DOWNLOADER='auto'
# export BILIBILI_COOKIE='<optional; improves bilibili comment/subtitle fetch stability>'
export YOUTUBE_TRANSCRIPT_FALLBACK_ENABLED='true'
export ASR_FALLBACK_ENABLED='false'
export ASR_MODEL_SIZE='small'
export PIPELINE_MAX_FRAMES='6'
export PIPELINE_FRAME_INTERVAL_SECONDS='30'
export PIPELINE_LLM_INPUT_MODE='auto'
# Optional override: force frame context include/exclude.
# export PIPELINE_LLM_INCLUDE_FRAMES='true'
export PIPELINE_LLM_HARD_REQUIRED='true'
export PIPELINE_LLM_FAIL_ON_PROVIDER_ERROR='true'
# export PIPELINE_LLM_MAX_RETRIES='3'
# Optional per-category retry overrides.
# export PIPELINE_RETRY_TRANSIENT_ATTEMPTS='2'
# export PIPELINE_RETRY_TRANSIENT_BACKOFF_SECONDS='1.0'
# export PIPELINE_RETRY_TRANSIENT_MAX_BACKOFF_SECONDS='8.0'
# export PIPELINE_RETRY_RATE_LIMIT_ATTEMPTS='3'
# export PIPELINE_RETRY_RATE_LIMIT_BACKOFF_SECONDS='2.0'
# export PIPELINE_RETRY_RATE_LIMIT_MAX_BACKOFF_SECONDS='16.0'
# export PIPELINE_RETRY_AUTH_ATTEMPTS='0'
# export PIPELINE_RETRY_AUTH_BACKOFF_SECONDS='1.0'
# export PIPELINE_RETRY_AUTH_MAX_BACKOFF_SECONDS='2.0'
# export PIPELINE_RETRY_FATAL_ATTEMPTS='0'
# export DIGEST_TEMPLATE_PATH='<optional-custom-template-path>'
export DIGEST_LOCAL_TIMEZONE='America/Los_Angeles'
export DIGEST_DAILY_LOCAL_HOUR='9'

# ---------- LLM / External APIs ----------
# export GEMINI_API_KEY='<optional>'
export GEMINI_MODEL='gemini-3.1-pro-preview'
export GEMINI_OUTLINE_MODEL='gemini-3.1-pro-preview'
export GEMINI_DIGEST_MODEL='gemini-3.1-pro-preview'
export GEMINI_FAST_MODEL='gemini-3-flash-preview'
export GEMINI_EMBEDDING_MODEL='gemini-embedding-001'
# Gemini thinking strategy: minimal|low|medium|high
export GEMINI_THINKING_LEVEL='high'
# Keep false for strict JSON-only downstream parsing.
export GEMINI_INCLUDE_THOUGHTS='false'
# Keep true to enforce strict schema validation on Gemini structured outputs.
export GEMINI_STRICT_SCHEMA_MODE='true'
# Gemini context caching for long text prompts.
export GEMINI_CONTEXT_CACHE_ENABLED='true'
export GEMINI_CONTEXT_CACHE_TTL_SECONDS='21600'
export GEMINI_CONTEXT_CACHE_MIN_CHARS='4096'
export GEMINI_CONTEXT_CACHE_MAX_KEYS='1000'
export GEMINI_CONTEXT_CACHE_LOCAL_TTL_SECONDS='21600'
export GEMINI_CONTEXT_CACHE_SWEEP_INTERVAL_SECONDS='300'
export GEMINI_COMPUTER_USE_ENABLED='false'
export GEMINI_COMPUTER_USE_REQUIRE_CONFIRMATION='true'
export GEMINI_COMPUTER_USE_MAX_STEPS='3'
export GEMINI_COMPUTER_USE_TIMEOUT_SECONDS='30'
# export YOUTUBE_API_KEY='<optional>'

# ---------- Notifications ----------
export NOTIFICATION_ENABLED='false'
# Required when NOTIFICATION_ENABLED=true
# export RESEND_API_KEY='<required-when-notification-enabled>'
# export RESEND_FROM_EMAIL='Video Digestor <noreply@example.com>'
export NOTIFY_TO_EMAIL='you@example.com'

# ---------- Daily Digest Script ----------
export DIGEST_CHANNEL='email'
export DIGEST_DRY_RUN='false'
export DIGEST_FORCE='false'
export DIGEST_FALLBACK_ENABLED='1'
# export DIGEST_TO_EMAIL="$NOTIFY_TO_EMAIL"
# export DIGEST_DATE='2026-02-21'

# ---------- Live Smoke Script ----------
# Leave empty to follow API_PORT; set explicitly only when smoke should hit a different API target.
export LIVE_SMOKE_API_BASE_URL=''
export LIVE_SMOKE_API_PORT='8000'
export LIVE_SMOKE_HEALTH_PATH='/healthz'
export LIVE_SMOKE_TIMEOUT_SECONDS='180'
export LIVE_SMOKE_REQUIRE_API='1'
export LIVE_SMOKE_REQUIRE_SECRETS='0'
export LIVE_SMOKE_POLL_INTERVAL_SECONDS='3'
export LIVE_SMOKE_COMPUTER_USE_STRICT='1'
export LIVE_SMOKE_COMPUTER_USE_SKIP='0'
# Required when LIVE_SMOKE_COMPUTER_USE_SKIP='1'
# export LIVE_SMOKE_COMPUTER_USE_SKIP_REASON='CI runner has no computer_use harness'
# Optional override. Default command is: bash scripts/smoke_computer_use_local.sh --api-base-url "$VD_API_BASE_URL"
# export LIVE_SMOKE_COMPUTER_USE_CMD='bash scripts/smoke_computer_use_local.sh --api-base-url http://127.0.0.1:18000'
export YOUTUBE_SMOKE_URL='https://www.youtube.com/watch?v=dQw4w9WgXcQ'
export BILIBILI_SMOKE_URL='https://www.bilibili.com/video/BV1xx411c7mD'

# ---------- Failure Alerts Script ----------
export FAILURE_CHANNEL='email'
export FAILURE_LOOKBACK_HOURS='24'
export FAILURE_LIMIT='20'
export FAILURE_DRY_RUN='false'
export FAILURE_FORCE='false'
export FAILURE_FALLBACK_ENABLED='1'
# export FAILURE_TO_EMAIL="$NOTIFY_TO_EMAIL"

# ---------- Script Entry Overrides ----------
export API_APP='apps.api.app.main:app'
export API_HOST='127.0.0.1'
export API_PORT='8000'
export WORKER_DIR="$PWD/apps/worker"
export WORKER_ENTRY='worker.main'
export WORKER_COMMAND='run-worker'
export DEV_WORKER_SHOW_HINTS='1'
export MCP_DIR="$PWD/apps/mcp"
export MCP_ENTRY='apps.mcp.server'
export OUTPUT_PATH="$PWD/.env.local.example"
export INIT_ENV_FORCE='0'

# ---------- Ops Workflow Bootstrap Script ----------
export OPS_DAILY_LOCAL_HOUR='9'
export OPS_DAILY_TIMEZONE='system-local'
# export OPS_DAILY_TIMEZONE_OFFSET_MINUTES='480'
export OPS_DAILY_WORKFLOW_ID='daily-digest-workflow'
export OPS_DAILY_RUN_ONCE='0'
export OPS_NOTIFICATION_INTERVAL_MINUTES='10'
export OPS_NOTIFICATION_RETRY_BATCH_LIMIT='50'
export OPS_NOTIFICATION_WORKFLOW_ID='notification-retry-workflow'
export OPS_NOTIFICATION_RUN_ONCE='0'
export OPS_CANARY_INTERVAL_HOURS='1'
export OPS_CANARY_TIMEOUT_SECONDS='8'
export OPS_CANARY_WORKFLOW_ID='provider-canary-workflow'
export OPS_CANARY_RUN_ONCE='0'
export OPS_CLEANUP_INTERVAL_HOURS='6'
export OPS_CLEANUP_OLDER_THAN_HOURS='24'
# export OPS_CLEANUP_CACHE_OLDER_THAN_HOURS='24'
# export OPS_CLEANUP_CACHE_MAX_SIZE_MB='1024'
# export OPS_CLEANUP_WORKSPACE_DIR="$HOME/.video-digestor/workspace"
# export OPS_CLEANUP_CACHE_DIR="$HOME/.video-digestor/cache"
export OPS_CLEANUP_WORKFLOW_ID='cleanup-workspace-workflow'
export OPS_CLEANUP_RUN_ONCE='0'
export OPS_DRY_RUN='0'
export OPS_SHOW_HINTS='1'
