export OPS_CLEANUP_WORKFLOW_ID='cleanup-workspace-workflow'
export OPS_CLEANUP_RUN_ONCE='0'
export OPS_DRY_RUN='0'
export OPS_SHOW_HINTS='1'

# ---------- Optional Reader Stack (Miniflux + Nextflux) ----------
# Reader-stack profile moved to: env/profiles/reader.env
# Legacy .env.reader-stack is still supported for compatibility.
# Migration helper:
#   ./scripts/env/migrate_env_legacy.sh

# ---------- Full Stack Helper Scripts ----------
# bootstrap_full_stack.sh: local | gce
export PROFILE='local'
# recreate_gce_instance.sh overrides
# export GCP_PROJECT='<required-when-running-recreate-script>'
export GCP_ZONE='us-west1-b'
export INSTANCE_NAME='vd-prod'
export MACHINE_TYPE='e2-standard-2'
export DISK_SIZE='50GB'
export IMAGE_FAMILY='debian-12'
export IMAGE_PROJECT='debian-cloud'
# export GITHUB_REPO_URL='https://github.com/<org>/<repo>.git'
export FORCE_DELETE_INSTANCE='0'
export FORCE_REPLACE_APP_DIR='0'
# install deps in bootstrap (0/1)
export INSTALL_DEPS='1'
# start core services in bootstrap (0/1)
export WITH_CORE_SERVICES='1'
# start reader stack in bootstrap (0/1)
export WITH_READER_STACK='1'
# allow degrade mode when docker/network is unavailable (0/1)
export OFFLINE_FALLBACK='1'
# smoke_full_stack.sh
# export WEB_BASE_URL='http://127.0.0.1:3001'
export FULL_STACK_REQUIRE_READER='1'

# ---------- Core Services Stack (Docker Compose) ----------
# Used by: ./scripts/deploy_core_services.sh and bootstrap_full_stack.sh
export CORE_POSTGRES_PORT='5432'
export CORE_POSTGRES_DB='video_analysis'
export CORE_POSTGRES_USER='postgres'
export CORE_POSTGRES_PASSWORD='postgres'
export CORE_REDIS_PORT='6379'
export CORE_TEMPORAL_PORT='7233'

# ---------- Reader Sync (AI digest -> Miniflux) ----------
# Optional auth mode A (recommended):
# export MINIFLUX_API_TOKEN='<token>'
# Optional auth mode B (basic):
# export MINIFLUX_ADMIN_USERNAME='admin'
# export MINIFLUX_ADMIN_PASSWORD='change_me'
# Feed seed used on first-time auto-create:
export MINIFLUX_IMPORT_FEED_URL='https://miniflux.app/feed.xml'
# AI digest sync batch size
export AI_FEED_SYNC_LIMIT='20'
