{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-e2e-*/types/**/*.ts",
    ".next-e2e-*/dev/types/**/*.ts",
    ".next-e2e-chromium-p7819/types/**/*.ts",
    ".next-e2e-chromium-p7819/dev/types/**/*.ts",
    ".next-e2e-chromium-p40025/types/**/*.ts",
    ".next-e2e-chromium-p40025/dev/types/**/*.ts",
    ".next-e2e-chromium-p42749/types/**/*.ts",
    ".next-e2e-chromium-p42749/dev/types/**/*.ts",
    ".next-e2e-chromium-p44169/types/**/*.ts",
    ".next-e2e-chromium-p44169/dev/types/**/*.ts",
    ".next-e2e-chromium-p47107/types/**/*.ts",
    ".next-e2e-chromium-p47107/dev/types/**/*.ts",
    ".next-e2e-chromium-p50684/types/**/*.ts",
    ".next-e2e-chromium-p50684/dev/types/**/*.ts",
    ".next-e2e-chromium-p53422/types/**/*.ts",
    ".next-e2e-chromium-p53422/dev/types/**/*.ts",
    ".next-e2e-chromium-p75466/types/**/*.ts",
    ".next-e2e-chromium-p75466/dev/types/**/*.ts",
    ".next-e2e-chromium-p77431/types/**/*.ts",
    ".next-e2e-chromium-p77431/dev/types/**/*.ts",
    ".next-e2e-chromium-p80881/types/**/*.ts",
    ".next-e2e-chromium-p80881/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
