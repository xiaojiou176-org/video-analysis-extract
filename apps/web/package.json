{
	"name": "video-digestor-web",
	"private": true,
	"version": "0.1.0",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint . --ext .ts,.tsx",
		"test": "vitest run",
		"test:a11y": "vitest run __tests__/a11y-smoke.test.tsx",
		"test:e2e:perceived": "cd tests/e2e && uv run --with pytest --with playwright pytest test_mobile_breakpoints.py test_reduced_motion.py test_perceived_latency.py -q -rA --web-e2e-browser chromium --web-e2e-api-base-url ${WEB_E2E_API_BASE_URL:-http://127.0.0.1:18080} --web-e2e-device-profile mobile --web-e2e-reduced-motion reduce --web-e2e-cpu-throttle 4",
		"test:watch": "vitest",
		"lighthouse:check": "lighthouse http://127.0.0.1:3000 --only-categories=accessibility,best-practices --quiet --chrome-flags='--headless'"
	},
	"dependencies": {
		"next": "16.1.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "^10.0.0",
		"remark-gfm": "^4.0.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.10.2",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"@vitejs/plugin-react": "^5.1.4",
		"@vitest/coverage-v8": "^4.0.18",
		"axe-core": "^4.11.0",
		"eslint": "^9.17.0",
		"eslint-config-next": "16.1.6",
		"jest-axe": "^10.0.0",
		"jsdom": "^28.1.0",
		"typescript": "^5.7.2",
		"vitest": "^4.0.18"
	}
}
