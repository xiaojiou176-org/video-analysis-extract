{
  "version": 1,
  "rules": [
    {
      "id": "migrations",
      "when": [
        "infra/migrations/*.sql"
      ],
      "required_paths": [
        "README.md",
        "docs/runbook-local.md"
      ]
    },
    {
      "id": "pipeline_steps",
      "when": [
        "apps/worker/worker/pipeline/types.py"
      ],
      "special_check": "pipeline_steps_changed",
      "required_paths": [
        "docs/state-machine.md"
      ]
    },
    {
      "id": "env_contract",
      "when": [
        ".env.example",
        "infra/config/env.contract.json"
      ],
      "required_paths": [
        ".env.example",
        "ENVIRONMENT.md",
        "infra/config/env.contract.json"
      ]
    },
    {
      "id": "api_signature",
      "when": [
        "apps/api/app/routers/*.py",
        "apps/api/app/services/*.py",
        "apps/mcp/*.py",
        "apps/mcp/**/*.py"
      ],
      "required_paths": [
        "README.md",
        "docs/runbook-local.md",
        "docs/testing.md"
      ]
    },
    {
      "id": "schema_contract",
      "when": [
        "apps/mcp/schemas/tools.json",
        "contracts/generated/jsonschema/*.json"
      ],
      "required_paths": [
        "docs/testing.md"
      ]
    },
    {
      "id": "startup_topology",
      "when": [
        "scripts/dev_*.sh",
        "scripts/full_stack.sh",
        "scripts/bootstrap_full_stack.sh",
        "scripts/ci/smoke_full_stack.sh",
        "infra/compose/*.compose.yml",
        ".devcontainer/*",
        ".devcontainer/**"
      ],
      "required_paths": [
        "README.md",
        "docs/start-here.md",
        "docs/runbook-local.md"
      ]
    },
    {
      "id": "dependency_policy",
      "when": [
        "pyproject.toml",
        "uv.lock",
        "requirements*.txt",
        "requirements/*.txt",
        "apps/*/package.json",
        "apps/*/package-lock.json",
        "apps/*/pnpm-lock.yaml"
      ],
      "required_paths": [
        "docs/reference/dependency-governance.md"
      ]
    },
    {
      "id": "logging_policy",
      "when": [
        "scripts/dev_api.sh",
        "scripts/dev_worker.sh",
        "scripts/dev_mcp.sh",
        "scripts/runtime/run_daily_digest.sh",
        "scripts/runtime/run_failure_alerts.sh",
        "apps/api/app/security.py"
      ],
      "required_paths": [
        "docs/reference/logging.md"
      ]
    },
    {
      "id": "governance_render_outputs",
      "when": [
        ".github/workflows/ci.yml",
        ".github/workflows/release-evidence-attest.yml",
        ".github/workflows/build-ci-standard-image.yml",
        "infra/config/strict_ci_contract.json",
        "infra/config/self_hosted_runner_baseline.json",
        "scripts/release/capture_release_manifest.sh",
        "artifacts/releases/README.md",
        "config/docs/*.json"
      ],
      "required_paths": [
        "README.md",
        "docs/start-here.md",
        "docs/runbook-local.md",
        "docs/testing.md",
        "docs/reference/external-lane-status.md"
      ]
    },
    {
      "id": "public_governance_pack",
      "when": [
        "LICENSE",
        "SECURITY.md",
        "CONTRIBUTING.md",
        "SUPPORT.md",
        ".github/CODEOWNERS",
        ".github/ISSUE_TEMPLATE/**",
        ".github/PULL_REQUEST_TEMPLATE.md"
      ],
      "required_paths": [
        "README.md",
        "docs/reference/done-model.md",
        "docs/reference/public-repo-readiness.md",
        "docs/reference/public-artifact-exposure.md",
        "docs/reference/public-rights-and-provenance.md",
        "docs/reference/public-privacy-and-data-boundary.md",
        "docs/reference/public-brand-boundary.md"
      ]
    },
    {
      "id": "high_signal_positioning",
      "when": [
        "docs/architecture.md",
        "docs/reference/project-positioning.md",
        "docs/reference/ai-evaluation.md",
        "evals/**",
        "scripts/governance/check_eval_assets.py"
      ],
      "required_paths": [
        "README.md",
        "docs/reference/project-positioning.md",
        "docs/reference/ai-evaluation.md",
        "docs/reference/value-proof.md",
        "docs/reference/newcomer-result-proof.md"
      ]
    }
  ]
}
