{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useBlockStatements": "error",
        "noUselessElse": "error"
      },
      "correctness": {
        "noUnusedVariables": "error"
      }
    }
  }
}
