#!/usr/bin/env bash
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$HOOK_DIR/.." && pwd)"
cd "$ROOT_DIR"

echo "[pre-commit] quality gate (mode=pre-commit)"
"$ROOT_DIR/scripts/quality_gate.sh" \
  --mode pre-commit \
  --profile local

echo "[pre-commit] passed"
